<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <!-- ✅ ADD THIS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <title>Nestify</title>
</head>
<body>

  <!-- 🔹 NAVBAR -->
  <%- include("../includes/navbar.ejs") %>

  <!-- 🔥 FLASH MESSAGES -->
  <% if ((success && success.length > 0) || (error && error.length > 0)) { %>
  <div class="d-flex justify-content-center mt-4">
    <div class="alert <%= success && success.length > 0 ? 'alert-success' : 'alert-danger' %> 
         alert-dismissible fade show d-flex align-items-center"
         role="alert"
         style="
           min-width: 320px;
           max-width: 500px;
           padding: 14px 20px;
           border-radius: 14px;
         ">

      <!-- TEXT -->
      <div class="flex-grow-1 text-center pe-4">
        <%= success && success.length > 0 ? success[0] : error[0] %>
      </div>

      <!-- CLOSE BUTTON -->
      <button type="button"
              class="btn-close flex-shrink-0"
              style="transform: scale(0.9);"
              data-bs-dismiss="alert">
      </button>

    </div>
  </div>
<% } %>


  <!-- 🔹 MAIN CONTENT -->
  <div class="container mt-3">
    <%- body %>
  </div>

  <!-- 🔹 FOOTER -->
  <%- include("../includes/footer.ejs") %>

  <!-- ✅ Bootstrap + Validation Script -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>

  <link href="/css/rating.css" rel="stylesheet" />

</body>
</html>